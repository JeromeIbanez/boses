#!/bin/sh
# Block direct pushes to main.
# All changes must go through staging first.

while read local_ref local_sha remote_ref remote_sha; do
  if echo "$remote_ref" | grep -q "refs/heads/main"; then
    echo ""
    echo "❌ Direct push to main is blocked."
    echo "   Push to staging first: git push origin staging"
    echo "   Then merge staging → main via PR."
    echo ""
    exit 1
  fi
done

exit 0
